{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/test/smoke-live.test.ts",
      "!**/*.timestamp-*"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "includes": [
      "**",
      "!**/generated/tools/**/*.ts",
      "!**/*-commands.ts",
      "!**/tools/generated/**/*.json",
      "!**/site/skills.json",
      "!**/scripts/pre-deploy.ts",
      "!**/packages/sdk/generated/**"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": { "noExplicitAny": "error" },
      "style": { "useImportType": "error" }
    }
  }
}
