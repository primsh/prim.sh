{
  "name": "@primsh/domain",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "description": "DNS and domain management via Cloudflare",
  "repository": {
    "type": "git",
    "url": "https://github.com/primsh/prim",
    "directory": "packages/domain"
  },
  "license": "Apache-2.0",
  "author": "Prim (https://prim.sh)",
  "keywords": [
    "prim",
    "x402",
    "dns",
    "domain",
    "cloudflare"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "lint": "biome lint .",
    "format": "biome format .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run --exclude 'test/integration*.test.ts'",
    "test:integration": "vitest --run test/integration.generated.test.ts",
    "test:smoke": "vitest --run --passWithNoTests test/smoke-live.generated.test.ts test/smoke-live.custom.test.ts",
    "check": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "@primsh/x402-middleware": "workspace:*",
    "@x402/core": "^2.7.0",
    "hono": "^4.12.14"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^1.6.1"
  }
}
