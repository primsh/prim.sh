{
  "name": "@primsh/wallet",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./balance": "./src/balance.ts"
  },
  "description": "Encrypted crypto wallets with x402 payment integration",
  "repository": {
    "type": "git",
    "url": "https://github.com/primsh/prim",
    "directory": "packages/wallet"
  },
  "license": "Apache-2.0",
  "author": "Prim (https://prim.sh)",
  "keywords": [
    "prim",
    "x402",
    "crypto",
    "wallet",
    "usdc",
    "base"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "lint": "biome lint .",
    "format": "biome format .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run",
    "test:smoke": "vitest --run --passWithNoTests test/smoke-live.generated.test.ts test/smoke-live.custom.test.ts",
    "check": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "@primsh/x402-middleware": "workspace:*",
    "hono": "^4.12.9",
    "viem": "^2.47.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@x402/core": "^2.7.0",
    "typescript": "^5.6.3",
    "vitest": "^1.6.1"
  }
}
